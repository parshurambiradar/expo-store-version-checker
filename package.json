{
  "name": "@blitzcode/expo-store-version-checker",
  "version": "1.0.2",
  "description": "Expo package to check Play Store and App Store versions and display update modal",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
